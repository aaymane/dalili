---
export const prerender = true;
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = posts.find((p) => p.data.featured) || posts[0];
const rest = posts.filter((p) => p.id !== featured?.id);

const categoryColors: Record<string, string> = {
  'Visa': '#014df8',
  'Logement': '#F5B544',
  'Démarches': '#7B5CF5',
  'Vie étudiante': '#1FB17C',
  'Communauté': '#FF7259',
};

const formatDate = (d: Date) =>
  d.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' });
---

<Base
  title="Guides & blog — DALILI"
  description="Tous les guides pour réussir ton arrivée en France : visa, logement, CAF, banque, vie étudiante. Écrits par ceux qui sont passés par là."
>
  <Nav />
  <main class="dl-blog-page">
    <header class="dl-blog-hero container">
      <div class="dl-eyebrow reveal" style="color: var(--dl-blue)">Guides & récits</div>
      <h1 class="dl-blog-hero-title reveal reveal-delay-1">
        Tout ce qu'on aurait voulu<br/>
        <em>savoir avant.</em>
      </h1>
      <p class="dl-blog-hero-sub reveal reveal-delay-2">
        Les démarches, les pièges, les astuces. Écrits par des étudiants qui l'ont vécu —
        relus par nos mentors actifs.
      </p>
    </header>

    {featured && (
      <a href={`/blog/${featured.id}/`} class="dl-blog-featured container reveal">
        <div class="dl-blog-featured-meta">
          <span class="dl-blog-cat" style={`color: ${categoryColors[featured.data.category]}`}>
            <span class="dl-blog-cat-dot" style={`background: ${categoryColors[featured.data.category]}`}></span>
            {featured.data.category}
          </span>
          <span>·</span>
          <span>{formatDate(featured.data.pubDate)}</span>
          <span>·</span>
          <span>{featured.data.readTime} min de lecture</span>
        </div>
        <h2 class="dl-blog-featured-title">{featured.data.title}</h2>
        <p class="dl-blog-featured-desc">{featured.data.description}</p>
        <span class="dl-blog-featured-cta">
          Lire le guide
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 5l7 7-7 7"/></svg>
        </span>
      </a>
    )}

    <section class="dl-blog-grid container">
      {rest.map((p, i) => (
        <a href={`/blog/${p.id}/`} class={`dl-blog-card reveal reveal-delay-${(i % 4) + 1}`}>
          <div class="dl-blog-card-meta">
            <span class="dl-blog-cat" style={`color: ${categoryColors[p.data.category]}`}>
              <span class="dl-blog-cat-dot" style={`background: ${categoryColors[p.data.category]}`}></span>
              {p.data.category}
            </span>
            <span class="dl-blog-card-time">{p.data.readTime} min</span>
          </div>
          <h3 class="dl-blog-card-title">{p.data.title}</h3>
          <p class="dl-blog-card-desc">{p.data.description}</p>
          <div class="dl-blog-card-date">{formatDate(p.data.pubDate)}</div>
        </a>
      ))}
    </section>
  </main>
</Base>

<style>
  .dl-blog-page {
    padding-top: 120px;
    padding-bottom: clamp(80px, 12vw, 160px);
    background: var(--dl-cream);
  }

  /* Hero */
  .dl-blog-hero {
    padding-top: clamp(40px, 6vw, 80px);
    padding-bottom: clamp(48px, 8vw, 96px);
    max-width: 920px;
  }
  .dl-blog-hero .dl-eyebrow {
    display: inline-block;
    margin-bottom: 20px;
  }
  .dl-blog-hero-title {
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: clamp(36px, 6vw, 84px);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--dl-ink);
    margin-bottom: 24px;
  }
  .dl-blog-hero-title em {
    font-family: var(--dl-editorial);
    font-style: italic;
    font-weight: 400;
    color: var(--dl-blue);
  }
  .dl-blog-hero-sub {
    font-family: var(--dl-editorial);
    font-style: italic;
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.5;
    color: var(--dl-ink-2);
    max-width: 640px;
  }

  /* Featured card */
  .dl-blog-featured {
    display: block;
    margin-bottom: 64px;
    padding: 56px 48px;
    border-radius: var(--r-xl);
    background: #fff;
    border: 1px solid rgba(10, 14, 31, 0.05);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.8) inset, 0 24px 60px -20px rgba(10, 14, 31, 0.1);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s;
    position: relative;
    overflow: hidden;
  }
  .dl-blog-featured::before {
    content: '';
    position: absolute;
    top: -100px; right: -100px;
    width: 360px; height: 360px;
    background: radial-gradient(circle, rgba(1, 77, 248, 0.06), transparent 65%);
    pointer-events: none;
  }
  .dl-blog-featured:hover {
    transform: translateY(-4px);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.8) inset, 0 36px 80px -24px rgba(10, 14, 31, 0.18);
  }
  .dl-blog-featured-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--dl-display);
    font-weight: 600;
    font-size: 12.5px;
    color: var(--dl-ink-3);
    margin-bottom: 24px;
  }
  .dl-blog-featured-title {
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: clamp(28px, 3.6vw, 48px);
    line-height: 1.08;
    letter-spacing: -0.02em;
    color: var(--dl-ink);
    margin-bottom: 16px;
    max-width: 720px;
  }
  .dl-blog-featured-desc {
    font-family: var(--dl-editorial);
    font-style: italic;
    font-size: clamp(16px, 1.4vw, 19px);
    line-height: 1.55;
    color: var(--dl-ink-2);
    margin-bottom: 28px;
    max-width: 600px;
  }
  .dl-blog-featured-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: 14px;
    color: var(--dl-blue);
  }

  /* Grid */
  .dl-blog-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .dl-blog-card {
    padding: 28px;
    border-radius: var(--r-lg);
    background: #fff;
    border: 1px solid rgba(10, 14, 31, 0.05);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s, border-color 0.3s;
    display: flex;
    flex-direction: column;
  }
  .dl-blog-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 24px 50px -16px rgba(10, 14, 31, 0.14);
    border-color: rgba(10, 14, 31, 0.1);
  }
  .dl-blog-card-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }
  .dl-blog-cat {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
  }
  .dl-blog-cat-dot {
    width: 6px; height: 6px; border-radius: 50%;
  }
  .dl-blog-card-time {
    font-family: var(--dl-display);
    font-weight: 600;
    font-size: 11px;
    color: var(--dl-ink-4);
  }
  .dl-blog-card-title {
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: 20px;
    line-height: 1.18;
    letter-spacing: -0.015em;
    color: var(--dl-ink);
    margin-bottom: 12px;
    flex: 1;
  }
  .dl-blog-card-desc {
    font-size: 14px;
    line-height: 1.55;
    color: var(--dl-ink-3);
    margin-bottom: 20px;
  }
  .dl-blog-card-date {
    font-family: var(--dl-display);
    font-weight: 600;
    font-size: 11.5px;
    color: var(--dl-ink-4);
  }

  @media (max-width: 900px) {
    .dl-blog-grid { grid-template-columns: 1fr; gap: 16px; }
    .dl-blog-featured { padding: 32px 24px; }
  }
</style>
