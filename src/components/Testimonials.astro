---
// DALILI · Testimonials — editorial style, real student journeys

const testimonials = [
  {
    quote: "J'ai déposé mon dossier visa toute seule pendant 3 mois. Refusé deux fois. Une session avec Camille sur DALILI, et j'avais le bon dossier en une après-midi.",
    name: 'Aïcha Diallo',
    journey: 'Tunis → Paris',
    field: 'Master Finance · Dauphine',
    hue: 350,
  },
  {
    quote: "Famille Lemoine m'a accueilli 5 jours quand mon studio n'était pas prêt. On était à table le soir 1. Aujourd'hui je passe les fêtes chez eux.",
    name: 'Mateo Silva',
    journey: 'São Paulo → Lyon',
    field: 'L3 Informatique · INSA',
    hue: 220,
  },
  {
    quote: "La communauté vietnamienne à Paris m'a tout appris : où acheter du nuoc-mâm, comment ouvrir un compte, où prier le matin. Je ne me suis jamais sentie seule.",
    name: 'Linh Nguyen',
    journey: 'Hanoï → Paris',
    field: 'Master Droit · Panthéon-Assas',
    hue: 12,
  },
];
---

<section class="dl-testimonials">
  <div class="container">
    <div class="dl-testi-head">
      <div class="dl-eyebrow reveal" style="color: var(--dl-violet)">Témoignages</div>
      <h2 class="dl-testi-title reveal reveal-delay-1">
        Ce qu'ils en disent.
      </h2>
    </div>

    <div class="dl-testi-grid">
      {testimonials.map((t, i) => (
        <article class={`dl-testi reveal reveal-delay-${i + 1}`} style={`--hue: ${t.hue}`}>
          <div class="dl-testi-quote-mark" aria-hidden="true">"</div>
          <blockquote class="dl-testi-quote">{t.quote}</blockquote>
          <footer class="dl-testi-footer">
            <div class="dl-testi-avatar">
              <span>{t.name.split(' ').map(w => w[0]).join('')}</span>
            </div>
            <div>
              <div class="dl-testi-name">{t.name}</div>
              <div class="dl-testi-meta">{t.journey} · {t.field}</div>
            </div>
          </footer>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .dl-testimonials {
    padding: clamp(80px, 12vw, 160px) 0;
    background: var(--dl-bg);
  }
  .dl-testi-head {
    max-width: 720px;
    margin: 0 0 64px;
  }
  .dl-testi-head .dl-eyebrow {
    display: inline-block;
    margin-bottom: 16px;
  }
  .dl-testi-title {
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: clamp(32px, 4.5vw, 64px);
    line-height: 1;
    letter-spacing: -0.025em;
    color: var(--dl-ink);
  }

  .dl-testi-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .dl-testi {
    position: relative;
    padding: 36px 32px;
    border-radius: var(--r-lg);
    background: rgba(255,255,255,0.04);
    border: 0.5px solid rgba(255,255,255,0.08);
    backdrop-filter: blur(16px);
    transition: transform 0.4s var(--ease-out), box-shadow 0.4s, border-color 0.3s;
    overflow: hidden;
  }
  .dl-testi:hover {
    transform: translateY(-4px);
    border-color: rgba(1,77,248,0.18);
    box-shadow: 0 24px 50px -16px rgba(10, 14, 31, 0.12);
  }

  .dl-testi-quote-mark {
    font-family: var(--dl-editorial);
    font-style: italic;
    font-size: 80px;
    line-height: 0.6;
    color: hsl(var(--hue), 70%, 55%);
    opacity: 0.18;
    margin-bottom: -10px;
  }

  .dl-testi-quote {
    font-family: var(--dl-editorial);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(17px, 1.4vw, 19px);
    line-height: 1.55;
    color: var(--dl-ink);
    margin-bottom: 28px;
  }

  .dl-testi-footer {
    display: flex;
    align-items: center;
    gap: 14px;
    padding-top: 20px;
    border-top: 0.5px solid rgba(10, 14, 31, 0.08);
  }
  .dl-testi-avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: linear-gradient(135deg, hsl(var(--hue), 75%, 62%), hsl(calc(var(--hue) + 40), 70%, 42%));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: 14px;
    flex-shrink: 0;
  }
  .dl-testi-name {
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: 14.5px;
    color: var(--dl-ink);
    margin-bottom: 2px;
  }
  .dl-testi-meta {
    font-size: 12px;
    color: var(--dl-ink-3);
  }

  @media (max-width: 900px) {
    .dl-testi-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }
</style>
