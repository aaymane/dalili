---
// DALILI Nav v2 — dark, minimal, premium
---

<header class="dl-nav" id="nav" role="banner">
  <div class="dl-nav-inner">

    <!-- Wordmark -->
    <a href="/" class="dl-wordmark" aria-label="DALILI — accueil">
      DALI
      <span class="dl-wordmark-accent">
        L<span class="dl-wordmark-dot" aria-hidden="true"></span>
      </span>
      I
    </a>

    <!-- Desktop links -->
    <nav class="dl-nav-links" aria-label="Navigation principale">
      <a href="/#story"     class="dl-nav-link">Histoire</a>
      <a href="/#ecosystem" class="dl-nav-link">Produit</a>
      <a href="/blog"       class="dl-nav-link">Guides</a>
    </nav>

    <!-- Desktop CTA — waitlist -->
    <a href="/#hero" class="dl-nav-cta" data-cursor="hover">
      <span class="dl-nav-cta-dot" aria-hidden="true"></span>
      <span>Rejoindre la liste</span>
      <svg class="dl-nav-cta-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7"/>
      </svg>
    </a>

    <!-- Mobile burger -->
    <button
      class="dl-burger"
      id="nav-burger"
      aria-label="Ouvrir le menu"
      aria-expanded="false"
      aria-controls="nav-sheet"
    >
      <span class="dl-burger-bar"></span>
      <span class="dl-burger-bar"></span>
    </button>
  </div>

  <!-- Mobile slide-down -->
  <div class="dl-nav-sheet" id="nav-sheet" role="dialog" aria-label="Menu navigation" aria-hidden="true">
    <nav class="dl-sheet-links">
      <a href="/#story"     class="dl-sheet-link">Histoire</a>
      <a href="/#ecosystem" class="dl-sheet-link">Produit</a>
      <a href="/blog"       class="dl-sheet-link">Guides</a>
    </nav>
    <a href="/#hero" class="dl-sheet-cta">
      Rejoindre la liste d'attente
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14M13 5l7 7-7 7"/>
      </svg>
    </a>
  </div>
</header>

<style>
  /* ── Shell ──────────────────────────────────────────────── */
  .dl-nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    padding: 18px var(--gutter);
    transition:
      background 0.4s var(--ease-out),
      border-color 0.4s,
      padding 0.3s;
    border-bottom: 0.5px solid transparent;
  }

  .dl-nav.scrolled {
    background: rgba(2, 4, 15, 0.85);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);
    border-bottom-color: rgba(255,255,255,0.06);
    padding-top: 12px;
    padding-bottom: 12px;
  }

  /* ── Inner row ──────────────────────────────────────────── */
  .dl-nav-inner {
    max-width: var(--max-w);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 28px;
  }

  /* ── Wordmark ───────────────────────────────────────────── */
  .dl-wordmark {
    font-family: var(--dl-display);
    font-weight: 900;
    font-size: 22px;
    letter-spacing: 0.08em;
    color: var(--dl-text-1);
    display: inline-flex;
    align-items: center;
    line-height: 1;
    flex-shrink: 0;
    user-select: none;
  }

  .dl-wordmark-accent {
    color: var(--dl-blue);
    position: relative;
    display: inline-flex;
  }

  .dl-wordmark-dot {
    position: absolute;
    top: -1px;
    right: -4px;
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--dl-blue);
    box-shadow: 0 0 10px var(--dl-blue), 0 0 20px rgba(1,77,248,0.4);
    animation: dotPulse 2.5s ease-in-out infinite;
  }

  @keyframes dotPulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.4; transform: scale(0.7); }
  }

  /* ── Desktop nav links ──────────────────────────────────── */
  .dl-nav-links {
    display: flex;
    gap: 36px;
  }

  .dl-nav-link {
    font-family: var(--dl-display);
    font-weight: 600;
    font-size: 13.5px;
    color: var(--dl-text-3);
    letter-spacing: 0.02em;
    position: relative;
    transition: color 0.2s;
  }

  .dl-nav-link::after {
    content: '';
    position: absolute;
    left: 0; bottom: -3px;
    width: 100%; height: 1px;
    background: var(--dl-blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s var(--ease-expo);
    border-radius: 1px;
  }

  .dl-nav-link:hover { color: var(--dl-text-1); }
  .dl-nav-link:hover::after { transform: scaleX(1); }

  /* ── Desktop CTA ────────────────────────────────────────── */
  .dl-nav-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px 10px 14px;
    border-radius: var(--r-sm);
    background: linear-gradient(135deg, var(--dl-blue), var(--dl-blue-deep));
    color: #fff;
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: 13px;
    letter-spacing: -0.005em;
    flex-shrink: 0;
    position: relative;
    overflow: hidden;
    box-shadow: 0 4px 20px -6px rgba(1,77,248,0.6);
    transition:
      transform 0.2s var(--ease-expo),
      box-shadow 0.2s;
  }

  .dl-nav-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 30%, rgba(255,255,255,0.18) 50%, transparent 70%);
    transform: translateX(-100%);
    transition: transform 0.5s;
  }
  .dl-nav-cta:hover::before { transform: translateX(100%); }

  .dl-nav-cta:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 32px -6px rgba(1,77,248,0.8);
  }

  .dl-nav-cta-dot {
    width: 6px; height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.7);
    animation: dotPulse 2s ease-in-out infinite;
    flex-shrink: 0;
  }

  .dl-nav-cta-arrow {
    transition: transform 0.25s var(--ease-expo);
  }
  .dl-nav-cta:hover .dl-nav-cta-arrow { transform: translateX(2px); }

  /* ── Burger ─────────────────────────────────────────────── */
  .dl-burger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 6px;
    width: 42px; height: 42px;
    border-radius: 10px;
    background: rgba(255,255,255,0.05);
    border: 0.5px solid rgba(255,255,255,0.08);
    cursor: pointer;
    padding: 0;
  }

  .dl-burger-bar {
    display: block;
    width: 20px; height: 1.5px;
    background: var(--dl-text-2);
    border-radius: 1px;
    transform-origin: center;
    transition: transform 0.35s var(--ease-expo), opacity 0.2s, width 0.3s;
  }

  .dl-burger[aria-expanded="true"] .dl-burger-bar:nth-child(1) {
    transform: translateY(3.75px) rotate(45deg);
  }
  .dl-burger[aria-expanded="true"] .dl-burger-bar:nth-child(2) {
    transform: translateY(-3.75px) rotate(-45deg);
  }

  /* ── Mobile sheet ───────────────────────────────────────── */
  .dl-nav-sheet {
    position: fixed;
    top: 64px; left: 0; right: 0;
    background: rgba(2, 4, 15, 0.97);
    backdrop-filter: blur(24px);
    border-bottom: 0.5px solid rgba(255,255,255,0.06);
    padding: 20px var(--gutter) 32px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transform: translateY(-20px);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.35s var(--ease-expo),
      transform 0.35s var(--ease-expo);
    z-index: 99;
  }

  .dl-nav-sheet.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .dl-sheet-links {
    display: flex;
    flex-direction: column;
  }

  .dl-sheet-link {
    padding: 15px 0;
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: 20px;
    color: var(--dl-text-2);
    border-bottom: 0.5px solid rgba(255,255,255,0.05);
    transition: color 0.2s;
  }
  .dl-sheet-link:hover { color: var(--dl-text-1); }
  .dl-sheet-link:last-child { border-bottom: none; }

  .dl-sheet-cta {
    margin-top: 20px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 16px 24px;
    border-radius: var(--r-sm);
    background: linear-gradient(135deg, var(--dl-blue), var(--dl-blue-deep));
    color: #fff;
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: 15px;
    box-shadow: 0 8px 32px -8px rgba(1,77,248,0.6);
  }

  /* ── Breakpoints ────────────────────────────────────────── */
  @media (max-width: 820px) {
    .dl-nav-links, .dl-nav-cta { display: none; }
    .dl-burger { display: flex; }
  }
</style>

<script>
  // Scroll state
  const nav = document.getElementById('nav');
  const tick = () => nav?.classList.toggle('scrolled', window.scrollY > 32);
  tick();
  window.addEventListener('scroll', tick, { passive: true });

  // Burger toggle
  const burger = document.getElementById('nav-burger');
  const sheet  = document.getElementById('nav-sheet');

  burger?.addEventListener('click', () => {
    const isOpen = sheet?.classList.toggle('open');
    burger.setAttribute('aria-expanded', String(!!isOpen));
    sheet?.setAttribute('aria-hidden', String(!isOpen));
    burger.setAttribute('aria-label', isOpen ? 'Fermer le menu' : 'Ouvrir le menu');
  });

  // Close on link tap
  sheet?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      sheet.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
    })
  );

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (sheet?.classList.contains('open') && !nav?.contains(e.target as Node)) {
      sheet.classList.remove('open');
      burger?.setAttribute('aria-expanded', 'false');
    }
  });
</script>
