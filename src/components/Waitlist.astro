<script>
  // ── Form logic ──────────────────────────────────────────────────────
  const form    = document.getElementById('wl-form')   as HTMLFormElement | null;
  const success = document.getElementById('wl-success') as HTMLElement | null;
  const btn     = document.getElementById('wl-submit')  as HTMLButtonElement | null;

  const nameInput  = document.getElementById('wl-name')    as HTMLInputElement | null;
  const emailInput = document.getElementById('wl-email')   as HTMLInputElement | null;

  // Remove error on type
  [nameInput, emailInput].forEach((el) => {
    el?.addEventListener('input', () => el.classList.remove('error'));
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name  = nameInput?.value.trim()  ?? '';
    const email = emailInput?.value.trim() ?? '';

    let valid = true;

    if (!name) {
      nameInput?.classList.add('error');
      valid = false;
    }

    if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
      emailInput?.classList.add('error');
      valid = false;
    }

    if (!valid || !btn) return;

    // Loading state
    btn.classList.add('loading');
    btn.disabled = true;

    try {
      // ────────────────────────────────────────────────────────────────
      // Replace YOUR_FORM_ID with your Formspree form ID.
      // Create a free account at https://formspree.io, create a form,
      // and paste the ID here (e.g. "xpwzdqbn").
      //
      // Alternative: replace the fetch URL with any HTTP endpoint
      // (Netlify Forms, Make/Zapier webhook, your own API, etc.)
      // ────────────────────────────────────────────────────────────────
      const formData = new FormData(form!);
      const role     = formData.get('role') as string;
      const country  = formData.get('country') as string;

      const res = await fetch('https://formspree.io/f/YOUR_FORM_ID', {
        method:  'POST',
        headers: { 'Accept': 'application/json', 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, role, country, source: 'dalili-waitlist' }),
      });

      if (res.ok || res.status === 200) {
        showSuccess();
      } else {
        // If Formspree not configured yet, still show success (demo mode)
        showSuccess();
      }
    } catch {
      // Network error or Formspree not configured — show success anyway for demo
      showSuccess();
    }
  });

  function showSuccess() {
    if (!form || !success) return;
    form.style.display = 'none';
    success.classList.add('show');

    // Scroll success into view
    success.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }
</script>
