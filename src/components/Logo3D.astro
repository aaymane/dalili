---
// DALILI Logo3D — cinematic Three.js logo reveal section
---

<section class="dl-logo3d" id="logo3d">
  <canvas class="dl-logo3d-canvas" id="logo3d-canvas" aria-hidden="true"></canvas>

  <!-- Layered vignette overlays -->
  <div class="dl-logo3d-vignette" aria-hidden="true"></div>

  <!-- Content overlay -->
  <div class="dl-logo3d-overlay">
    <div class="dl-logo3d-label reveal">
      <span class="dl-logo3d-label-dot" aria-hidden="true"></span>
      Une identité. Une mission.
    </div>
    <p class="dl-logo3d-tagline reveal reveal-delay-2">
      DALILI — ton guide en France
    </p>
  </div>

  <!-- Scroll hint -->
  <div class="dl-logo3d-scroll" aria-hidden="true">
    <span class="dl-logo3d-scroll-line"></span>
  </div>
</section>

<style>
  .dl-logo3d {
    position: relative;
    height: 100vh;
    height: 100svh;
    overflow: hidden;
    background: #040818;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding-bottom: 80px;
  }

  .dl-logo3d-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
  }

  .dl-logo3d-vignette {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 60% 60% at 50% 50%, transparent 30%, rgba(4, 8, 24, 0.7) 100%),
      linear-gradient(to top, rgba(4, 8, 24, 0.9) 0%, transparent 30%),
      linear-gradient(to bottom, rgba(4, 8, 24, 0.6) 0%, transparent 20%);
    pointer-events: none;
    z-index: 1;
  }

  .dl-logo3d-overlay {
    position: relative;
    z-index: 2;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  .dl-logo3d-label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 18px 8px 12px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.06);
    border: 0.5px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: 11.5px;
    color: rgba(255, 255, 255, 0.5);
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .dl-logo3d-label-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--dl-blue);
    box-shadow: 0 0 12px var(--dl-blue);
    animation: pulseDot 2s ease-in-out infinite;
  }

  @keyframes pulseDot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(0.8); }
  }

  .dl-logo3d-tagline {
    font-family: var(--dl-display);
    font-weight: 700;
    font-size: clamp(22px, 3vw, 36px);
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.15);
    text-transform: uppercase;
    user-select: none;
  }

  .dl-logo3d-scroll {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    width: 1px;
    height: 56px;
    background: linear-gradient(to bottom, transparent, rgba(1, 77, 248, 0.6));
    overflow: hidden;
  }

  .dl-logo3d-scroll-line {
    display: block;
    width: 100%;
    height: 50%;
    background: linear-gradient(to bottom, transparent, rgba(74, 126, 255, 0.9));
    animation: scrollDrop 2s ease-in-out infinite;
  }

  @keyframes scrollDrop {
    0% { transform: translateY(-100%); opacity: 0; }
    30% { opacity: 1; }
    100% { transform: translateY(200%); opacity: 0; }
  }
</style>

<script>
  import * as THREE from 'three';

  const canvas = document.getElementById('logo3d-canvas') as HTMLCanvasElement | null;
  if (!canvas) throw new Error('Logo3D canvas not found');

  // ── Scene & camera ─────────────────────────────────────────────────
  const scene = new THREE.Scene();
  scene.fog = new THREE.FogExp2(0x040818, 0.035);

  const camera = new THREE.PerspectiveCamera(
    55,
    canvas.clientWidth / canvas.clientHeight,
    0.1,
    200
  );
  camera.position.set(0, 0, 7);

  const renderer = new THREE.WebGLRenderer({ canvas, alpha: false, antialias: true });
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
  renderer.setSize(canvas.clientWidth, canvas.clientHeight);
  renderer.setClearColor(0x040818, 1);
  renderer.shadowMap.enabled = false;
  renderer.toneMapping = THREE.ACESFilmicToneMapping;
  renderer.toneMappingExposure = 1.4;

  // ── Lights ─────────────────────────────────────────────────────────
  const ambientLight = new THREE.AmbientLight(0x1a1f4e, 2.5);
  scene.add(ambientLight);

  const bluePoint = new THREE.PointLight(0x014df8, 80, 18);
  bluePoint.position.set(3, 2, 4);
  scene.add(bluePoint);

  const whitePoint = new THREE.PointLight(0xffffff, 40, 14);
  whitePoint.position.set(-3, -1, 3);
  scene.add(whitePoint);

  const rimLight = new THREE.PointLight(0x4a7eff, 30, 12);
  rimLight.position.set(0, -4, -3);
  scene.add(rimLight);

  // ── Logo geometry ──────────────────────────────────────────────────

  // Helper: octagonal shape
  function makeOctagon(r: number) {
    const shape = new THREE.Shape();
    const n = 8;
    for (let i = 0; i <= n; i++) {
      const a = (i / n) * Math.PI * 2 + Math.PI / 8;
      const x = Math.cos(a) * r;
      const y = Math.sin(a) * r;
      if (i === 0) shape.moveTo(x, y);
      else shape.lineTo(x, y);
    }
    return shape;
  }

  // Outer octagonal ring (frame)
  const outerShape = makeOctagon(1.52);
  const innerHole = new THREE.Path();
  const n = 8;
  for (let i = 0; i <= n; i++) {
    const a = (i / n) * Math.PI * 2 + Math.PI / 8;
    if (i === 0) innerHole.moveTo(Math.cos(a) * 1.08, Math.sin(a) * 1.08);
    else innerHole.lineTo(Math.cos(a) * 1.08, Math.sin(a) * 1.08);
  }
  outerShape.holes.push(innerHole);

  const extSettings: THREE.ExtrudeGeometryOptions = {
    depth: 0.32,
    bevelEnabled: true,
    bevelThickness: 0.06,
    bevelSize: 0.05,
    bevelSegments: 4,
  };
  const frameGeo = new THREE.ExtrudeGeometry(outerShape, extSettings);
  frameGeo.center();

  const frameMat = new THREE.MeshPhongMaterial({
    color: 0x014df8,
    emissive: 0x0028a0,
    emissiveIntensity: 0.5,
    shininess: 180,
    specular: 0x88aaff,
  });

  const frameMesh = new THREE.Mesh(frameGeo, frameMat);
  frameMesh.castShadow = false;
  scene.add(frameMesh);

  // Wireframe overlay for depth
  const wireGeo = frameGeo.clone();
  const wireMat = new THREE.MeshBasicMaterial({
    color: 0x4a7eff,
    wireframe: true,
    transparent: true,
    opacity: 0.08,
  });
  const wireMesh = new THREE.Mesh(wireGeo, wireMat);
  scene.add(wireMesh);

  // ── S-curve: upper C ────────────────────────────────────────────────
  const upperCurve = new THREE.CatmullRomCurve3([
    new THREE.Vector3(-0.1, 0.88, 0.16),
    new THREE.Vector3( 0.55, 0.80, 0.16),
    new THREE.Vector3( 0.72, 0.40, 0.16),
    new THREE.Vector3( 0.70, 0.10, 0.16),
    new THREE.Vector3( 0.52, 0.0,  0.16),
    new THREE.Vector3( 0.0,  0.0,  0.16),
  ]);
  const upperTubeGeo = new THREE.TubeGeometry(upperCurve, 48, 0.105, 10, false);
  const innerMat = new THREE.MeshPhongMaterial({
    color: 0xffffff,
    emissive: 0x9ab4ff,
    emissiveIntensity: 0.3,
    shininess: 120,
    specular: 0xffffff,
  });
  const upperTube = new THREE.Mesh(upperTubeGeo, innerMat);
  scene.add(upperTube);

  // Lower C (mirrored)
  const lowerCurve = new THREE.CatmullRomCurve3([
    new THREE.Vector3( 0.1, -0.88, 0.16),
    new THREE.Vector3(-0.55, -0.80, 0.16),
    new THREE.Vector3(-0.72, -0.40, 0.16),
    new THREE.Vector3(-0.70, -0.10, 0.16),
    new THREE.Vector3(-0.52,  0.0,  0.16),
    new THREE.Vector3( 0.0,   0.0,  0.16),
  ]);
  const lowerTubeGeo = new THREE.TubeGeometry(lowerCurve, 48, 0.105, 10, false);
  const lowerTube = new THREE.Mesh(lowerTubeGeo, innerMat);
  scene.add(lowerTube);

  // Group all logo parts
  const logoGroup = new THREE.Group();
  scene.add(logoGroup);

  // Move meshes into group
  scene.remove(frameMesh, wireMesh, upperTube, lowerTube);
  logoGroup.add(frameMesh, wireMesh, upperTube, lowerTube);
  logoGroup.rotation.x = 0.12;

  // ── Glow sprite ────────────────────────────────────────────────────
  const glowCanvas = document.createElement('canvas');
  glowCanvas.width = 256;
  glowCanvas.height = 256;
  const gc = glowCanvas.getContext('2d')!;
  const grd = gc.createRadialGradient(128, 128, 0, 128, 128, 128);
  grd.addColorStop(0,   'rgba(1,77,248,0.55)');
  grd.addColorStop(0.4, 'rgba(1,77,248,0.18)');
  grd.addColorStop(1,   'rgba(1,77,248,0)');
  gc.fillStyle = grd;
  gc.fillRect(0, 0, 256, 256);

  const glowTex = new THREE.CanvasTexture(glowCanvas);
  const glowMat = new THREE.SpriteMaterial({
    map: glowTex,
    blending: THREE.AdditiveBlending,
    transparent: true,
    opacity: 0.9,
    depthWrite: false,
  });
  const glowSprite = new THREE.Sprite(glowMat);
  glowSprite.scale.set(7, 7, 1);
  glowSprite.position.z = -0.5;
  logoGroup.add(glowSprite);

  // ── Particle field ─────────────────────────────────────────────────
  const PART_COUNT = 1800;
  const partPositions = new Float32Array(PART_COUNT * 3);
  const partColors   = new Float32Array(PART_COUNT * 3);
  const partSizes    = new Float32Array(PART_COUNT);

  for (let i = 0; i < PART_COUNT; i++) {
    const theta = Math.random() * Math.PI * 2;
    const phi   = Math.acos(Math.random() * 2 - 1);
    const r     = 3 + Math.random() * 18;
    partPositions[i * 3]     = Math.sin(phi) * Math.cos(theta) * r;
    partPositions[i * 3 + 1] = Math.sin(phi) * Math.sin(theta) * r;
    partPositions[i * 3 + 2] = Math.cos(phi) * r * 0.5;

    const t = Math.random();
    if (t < 0.5) {
      // Electric blue
      partColors[i * 3]     = 0.29;
      partColors[i * 3 + 1] = 0.49;
      partColors[i * 3 + 2] = 1.0;
    } else if (t < 0.8) {
      // Light blue
      partColors[i * 3]     = 0.45;
      partColors[i * 3 + 1] = 0.65;
      partColors[i * 3 + 2] = 1.0;
    } else {
      // White
      partColors[i * 3]     = 0.85;
      partColors[i * 3 + 1] = 0.88;
      partColors[i * 3 + 2] = 1.0;
    }
    partSizes[i] = 0.8 + Math.random() * 2.4;
  }

  const partGeo = new THREE.BufferGeometry();
  partGeo.setAttribute('position', new THREE.BufferAttribute(partPositions, 3));
  partGeo.setAttribute('color', new THREE.BufferAttribute(partColors, 3));
  partGeo.setAttribute('size', new THREE.BufferAttribute(partSizes, 1));

  const partMat = new THREE.PointsMaterial({
    size: 0.06,
    vertexColors: true,
    transparent: true,
    opacity: 0.75,
    sizeAttenuation: true,
    blending: THREE.AdditiveBlending,
    depthWrite: false,
  });

  const particles = new THREE.Points(partGeo, partMat);
  scene.add(particles);

  // ── Floating accent hexagons (distant) ─────────────────────────────
  const accentGroup = new THREE.Group();
  scene.add(accentGroup);

  const accentPositions = [
    [-6, 3, -8], [7, -4, -12], [-8, -5, -6], [5, 6, -10],
    [9, 1, -15], [-4, 7, -14], [3, -7, -9], [-7, 2, -18],
  ];

  accentPositions.forEach(([x, y, z], i) => {
    const r = 0.3 + Math.random() * 0.5;
    const geo = new THREE.CylinderGeometry(r, r, 0.04 + Math.random() * 0.06, 6);
    const mat = new THREE.MeshBasicMaterial({
      color: i % 3 === 0 ? 0x014df8 : i % 3 === 1 ? 0x1F2850 : 0x4a7eff,
      transparent: true,
      opacity: 0.12 + Math.random() * 0.14,
      wireframe: i % 2 === 0,
    });
    const mesh = new THREE.Mesh(geo, mat);
    mesh.position.set(x, y, z);
    mesh.rotation.x = Math.PI / 2;
    mesh.rotation.z = Math.random() * Math.PI;
    accentGroup.add(mesh);
  });

  // ── Mouse parallax ─────────────────────────────────────────────────
  let mouseX = 0, mouseY = 0;
  let targetX = 0, targetY = 0;

  document.addEventListener('mousemove', (e) => {
    mouseX = (e.clientX / window.innerWidth  - 0.5) * 2;
    mouseY = (e.clientY / window.innerHeight - 0.5) * 2;
  });

  // ── Animation loop ─────────────────────────────────────────────────
  let time = 0;

  const animate = () => {
    requestAnimationFrame(animate);
    time += 0.005;

    // Smooth mouse follow
    targetX += (mouseX - targetX) * 0.04;
    targetY += (mouseY - targetY) * 0.04;

    // Logo: auto-rotate + mouse tilt
    logoGroup.rotation.y = time * 0.35 + targetX * 0.25;
    logoGroup.rotation.x = 0.12  + targetY * -0.15;

    // Breathe scale
    const breathe = 1 + Math.sin(time * 1.2) * 0.018;
    logoGroup.scale.setScalar(breathe);

    // Glow pulse
    glowSprite.material.opacity = 0.7 + Math.sin(time * 2.2) * 0.18;

    // Particles: slow drift
    particles.rotation.y  =  time * 0.04;
    particles.rotation.x  =  time * 0.02;

    // Accents: drift
    accentGroup.children.forEach((child, i) => {
      child.rotation.z += 0.003 * (i % 2 === 0 ? 1 : -1);
      (child as THREE.Mesh).position.y +=
        Math.sin(time * 1.5 + i * 0.8) * 0.003;
    });

    // Camera subtle drift
    camera.position.x = targetX * 0.3;
    camera.position.y = targetY * -0.2;
    camera.lookAt(0, 0, 0);

    // Light orbit
    bluePoint.position.x  =  Math.cos(time * 0.6) * 4;
    bluePoint.position.z  =  Math.sin(time * 0.6) * 3 + 2;
    whitePoint.position.x = -Math.cos(time * 0.4) * 3;
    whitePoint.position.z =  Math.sin(time * 0.4) * 2 + 2;

    renderer.render(scene, camera);
  };

  animate();

  // ── Resize ──────────────────────────────────────────────────────────
  const onResize = () => {
    const w = canvas.clientWidth;
    const h = canvas.clientHeight;
    camera.aspect = w / h;
    camera.updateProjectionMatrix();
    renderer.setSize(w, h);
  };
  window.addEventListener('resize', onResize);
</script>
